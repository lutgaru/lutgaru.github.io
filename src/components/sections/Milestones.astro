---
// src/components/sections/Milestones.astro
interface Milestone {
  period: string;
  periodColor: "primary" | "secondary";
  title: string;
  description: string;
  tags: string[];
}

const milestones: Milestone[] = [
  {
    period: "2022 — PRESENT",
    periodColor: "primary",
    title: "Production Wireless Systems & BLE Architecture",
    description:
      "Designed and deployed multi-role BLE systems for commercial marine electronics (>5,000 units). Defined custom application-layer protocols and OTA update architecture, achieving ~50% power reduction and ~33% memory optimization.",
    tags: [
      "BLE Architecture",
      "RTOS",
      "Embedded Optimization",
      "CAN (NMEA 2000)",
    ],
  },
  {
    period: "2019 — 2022",
    periodColor: "primary",
    title: "IoT Security & Lightweight Cryptography Research",
    description:
      "Conducted research on lightweight cryptography for multihop IoMT networks using TI CC2650 hardware and simulated 6LoWPAN environments. Evaluated 8 NIST Lightweight Cryptography candidates, analyzing latency, energy, and memory trade-offs in constrained embedded systems.",
    tags: ["6LoWPAN", "IoT Security", "Python Automation", "Cryptography"],
  },
  {
    period: "2019",
    periodColor: "primary",
    title: "Painani 1 Satellite Ground Station",
    description:
      "Co-deployed and commissioned the ground station for the Mexican nanosatellite Painani 1. Developed custom rotor automation and UHF/VHF signal decoding software, coordinating telemetry operations through the SatNOGS international network.",
    tags: ["UHF/VHF Systems", "SatNOGS", "Embedded Linux", "Telemetry"],
  },
  {
    period: "2018",
    periodColor: "primary",
    title: "Maritime Wireless Systems Patent (IMPI #430014)",
    description:
      "Co-inventor of a patented wireless communication system with automatic compensation to maintain link integrity under dynamic sea conditions. Contributed to protocol design, firmware, and field validation.",
    tags: ["RF Systems", "Wireless Protocols", "Embedded C", "Field Testing"],
  },
];
---

<section
  class="py-24 px-6 md:px-margin max-w-container-max mx-auto border-x border-zinc-800"
  id="milestones"
>
  <div class="mb-16">
    <h2
      class="font-headline-md text-headline-md mb-4 uppercase tracking-tighter"
    >
      Professional Milestones
    </h2>
    <div class="h-1 w-24 bg-primary"></div>
  </div>

  <div class="space-y-px bg-zinc-800">
    {
      milestones.map((item) => (
        <div class="grid grid-cols-1 md:grid-cols-4 bg-background p-8 items-start hover:bg-zinc-900 transition-colors">
          <div class="mb-4 md:mb-0">
            <span
              class={`font-label-mono text-label-mono text-${item.periodColor}`}
            >
              {item.period}
            </span>
          </div>
          <div class="md:col-span-3">
            <h4 class="font-headline-md text-[24px] mb-2">{item.title}</h4>
            <p class="text-body-base text-on-surface-variant mb-4">
              {item.description}
            </p>
            <div class="flex gap-4">
              {item.tags.map((tag) => (
                <span class="text-code-sm font-code-sm text-zinc-600">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
