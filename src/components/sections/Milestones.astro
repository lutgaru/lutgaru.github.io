---
// src/components/sections/Milestones.astro
interface Milestone {
  period: string;
  periodColor: 'primary' | 'secondary';
  title: string;
  description: string;
  tags: string[];
}

const milestones: Milestone[] = [
  {
    period: '2022 — PRESENT',
    periodColor: 'primary',
    title: 'Production Wireless Systems & BLE Architecture',
    description: 'Designed and deployed multi-role BLE systems for commercial marine electronics (>5,000 units). Defined custom application-layer protocols and OTA update architecture, achieving ~50% power reduction and ~33% memory optimization.',
    tags: ['BLE Architecture', 'RTOS', 'Embedded Optimization', 'CAN (NMEA 2000)']
  },
  {
    period: '2019 — 2022',
    periodColor: 'secondary',
    title: 'Satellite Ground Station & IoT Security Research',
    description: 'Co-deployed a ground station for a Mexican nanosatellite, developing rotor control and UHF/VHF decoding systems. Conducted research on lightweight cryptography for IoT multihop networks on constrained devices.',
    tags: ['UHF/VHF Systems', 'Embedded Linux', '6LoWPAN', 'IoT Security']
  },
  {
    period: '2018',
    periodColor: 'primary',
    title: 'Maritime Wireless Systems Patent (IMPI #430014)',
    description: 'Co-inventor of a patented wireless communication system with automatic compensation to maintain link integrity under dynamic sea conditions. Contributed to protocol design, firmware, and field validation.',
    tags: ['RF Systems', 'Wireless Protocols', 'Embedded C', 'Field Testing']
  }
];
---

<section class="py-24 px-6 md:px-margin max-w-container-max mx-auto border-x border-zinc-800" id="milestones">
  <div class="mb-16">
    <h2 class="font-headline-md text-headline-md mb-4 uppercase tracking-tighter">Professional Milestones</h2>
    <div class="h-1 w-24 bg-primary"></div>
  </div>
  
  <div class="space-y-px bg-zinc-800">
    {milestones.map((item) => (
      <div class="grid grid-cols-1 md:grid-cols-4 bg-background p-8 items-start hover:bg-zinc-900 transition-colors">
        <div class="mb-4 md:mb-0">
          <span class={`font-label-mono text-label-mono text-${item.periodColor}`}>{item.period}</span>
        </div>
        <div class="md:col-span-3">
          <h4 class="font-headline-md text-[24px] mb-2">{item.title}</h4>
          <p class="text-body-base text-on-surface-variant mb-4">{item.description}</p>
          <div class="flex gap-4">
            {item.tags.map((tag) => (
              <span class="text-code-sm font-code-sm text-zinc-600">{tag}</span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>