---
// src/components/sections/Milestones.astro
interface Milestone {
  period: string;
  periodColor: 'primary' | 'secondary';
  title: string;
  description: string;
  tags: string[];
}

const milestones: Milestone[] = [
  {
    period: '2021 — PRESENT',
    periodColor: 'primary',
    title: 'Satellite Ground Station Firmware',
    description: 'Developed mission-critical control firmware for L-Band satellite transceiver systems. Optimized signal processing pipelines reducing latency.',
    tags: ['FPGA Integration', 'RTOS Scheduling']
  },
  {
    period: '2019 — 2021',
    periodColor: 'secondary',
    title: 'Marine Link Patent #US1029384',
    description: 'Primary inventor for a high-resiliency wireless bridge for maritime sensor networks. Covers dynamic frequency hopping algorithms.',
    tags: ['Intellectual Property', 'RF Engineering']
  }
];
---

<section class="py-24 px-6 md:px-margin max-w-container-max mx-auto border-x border-zinc-800" id="milestones">
  <div class="mb-16">
    <h2 class="font-headline-md text-headline-md mb-4 uppercase tracking-tighter">Professional_Milestones</h2>
    <div class="h-1 w-24 bg-primary"></div>
  </div>
  
  <div class="space-y-px bg-zinc-800">
    {milestones.map((item) => (
      <div class="grid grid-cols-1 md:grid-cols-4 bg-background p-8 items-start hover:bg-zinc-900 transition-colors">
        <div class="mb-4 md:mb-0">
          <span class={`font-label-mono text-label-mono text-${item.periodColor}`}>{item.period}</span>
        </div>
        <div class="md:col-span-3">
          <h4 class="font-headline-md text-[24px] mb-2">{item.title}</h4>
          <p class="text-body-base text-on-surface-variant mb-4">{item.description}</p>
          <div class="flex gap-4">
            {item.tags.map((tag) => (
              <span class="text-code-sm font-code-sm text-zinc-600">{tag}</span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>