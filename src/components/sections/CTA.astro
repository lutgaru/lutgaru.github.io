---
// src/components/sections/CTA.astro
---

<section
  class="py-24 border-t border-zinc-800 bg-surface-container-low text-center overflow-hidden relative"
  id="contact"
>
  <div
    class="absolute inset-0 flex justify-center items-center opacity-5 pointer-events-none"
  >
    <span
      class="text-[200px] font-black tracking-tighter font-mono whitespace-nowrap text-secondary"
      >INITIATE_HANDSHAKE</span
    >
  </div>

  <div class="relative z-10 max-w-2xl mx-auto px-6">
    <h2
      class="font-headline-lg text-headline-lg mb-8 uppercase tracking-tighter"
    >
      Let's Build Something Real
    </h2>
    <p class="text-body-base text-on-surface-variant mb-10">
      Open to embedded systems, wireless architecture, and firmware development
      opportunities.
    </p>
    <div class="inline-flex flex-col md:flex-row gap-6">
      <a
        href="mailto:adrianneftali.s@gmail.com"
        class="px-12 py-5 bg-primary text-on-primary font-label-mono text-label-mono uppercase tracking-[0.2em] hover:scale-105 transition-transform rust-glow"
      >
        Contact
      </a>
      <a
        class="px-12 py-5 border border-zinc-700 font-label-mono text-label-mono uppercase tracking-[0.2em] hover:bg-zinc-800 transition-colors"
        href="/cv/Adrian_Sanchez_Embedded_Engineer.pdf"
        target="_blank"
      >
        Download CV
      </a>
    </div>

    <!-- Social links -->
    <div class="flex justify-center gap-6 mt-10">
      <a
        href="https://x.com/lutgaru"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Twitter / X"
        class="group flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors font-label-mono text-label-mono uppercase tracking-[0.15em]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="group-hover:scale-110 transition-transform"
          aria-hidden="true"
        >
          <path
            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.259 5.631L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"
          ></path>
        </svg>
        <span>Twitter</span>
      </a>

      <span class="text-zinc-700 select-none">·</span>

      <a
        href="https://www.linkedin.com/in/adrian-neftali-sanchez/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="group flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors font-label-mono text-label-mono uppercase tracking-[0.15em]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="group-hover:scale-110 transition-transform"
          aria-hidden="true"
        >
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path>
        </svg>
        <span>LinkedIn</span>
      </a>
    </div>
  </div>
</section>
