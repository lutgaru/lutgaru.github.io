---
// src/components/sections/CTA.astro
---

<section
  class="py-24 border-t border-zinc-800 bg-surface-container-low text-center overflow-hidden relative"
>
  <div
    class="absolute inset-0 flex justify-center items-center opacity-5 pointer-events-none"
  >
    <span
      class="text-[200px] font-black tracking-tighter font-mono whitespace-nowrap text-secondary"
      >INITIATE_HANDSHAKE</span
    >
  </div>

  <div class="relative z-10 max-w-2xl mx-auto px-6">
    <h2
      class="font-headline-lg text-headline-lg mb-8 uppercase tracking-tighter"
    >
      Let's Build Something Real
    </h2>
    <p class="text-body-base text-on-surface-variant mb-10">
      Open to embedded systems, wireless architecture, and firmware development
      opportunities.
    </p>
    <div class="inline-flex flex-col md:flex-row gap-6">
      <a
        href="mailto:adrianneftali.s@gmail.com"
        class="px-12 py-5 bg-primary text-on-primary font-label-mono text-label-mono uppercase tracking-[0.2em] hover:scale-105 transition-transform rust-glow"
      >
        Contact
      </a>
      <a
        class="px-12 py-5 border border-zinc-700 font-label-mono text-label-mono uppercase tracking-[0.2em] hover:bg-zinc-800 transition-colors"
        href="/cv/Adrian_Sanchez_Embedded_Engineer.pdf"
        target="_blank"
      >
        Download CV
      </a>
    </div>
  </div>
</section>
