---

<style>
  html {
    scroll-behavior: smooth;
  }

  /* Hide the checkbox */
  #nav-toggle {
    display: none;
  }

  .nav-links {
    /* Mobile: hidden by default */
    display: none;
    flex-direction: column;
    position: absolute;
    top: 3.5rem; /* h-14 */
    left: 0;
    width: 100%;
    background-color: rgb(9 9 11 / 0.98); /* zinc-950 */
    border-bottom: 1px solid rgb(39 39 42); /* zinc-800 */
    padding: 1rem 1.5rem;
    gap: 1.25rem;
  }

  /* Show nav links when checkbox is checked */
  #nav-toggle:checked ~ nav .nav-links {
    display: flex;
  }

  /* Hamburger → X transition */
  .hamburger-bar {
    display: block;
    width: 1.25rem;
    height: 2px;
    background-color: rgb(244 244 245); /* zinc-100 */
    transition: transform 0.2s ease, opacity 0.2s ease;
    transform-origin: center;
  }

  #nav-toggle:checked ~ nav .hamburger-bar:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  #nav-toggle:checked ~ nav .hamburger-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #nav-toggle:checked ~ nav .hamburger-bar:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Desktop: always show nav, hide hamburger */
  @media (min-width: 768px) {
    .nav-links {
      display: flex !important;
      flex-direction: row;
      position: static;
      background: transparent;
      border: none;
      padding: 0;
      gap: 2rem;
      align-items: center;
      width: auto;
    }

    .hamburger-label {
      display: none;
    }
  }
</style>

<!-- Checkbox lives OUTSIDE nav so the ~ sibling selector can reach nav -->
<input type="checkbox" id="nav-toggle" aria-hidden="true" />

<nav class="fixed top-0 w-full z-50 flex flex-wrap justify-between items-center px-6 h-14 bg-zinc-950/95 border-b border-zinc-800">

  <!-- Logo -->
  <div class="text-lg font-black tracking-widest text-zinc-100 font-mono">
    Adrian Sanchez
    <span class="text-zinc-500 text-xs ml-2">/ lutgaru</span>
  </div>

  <!-- Hamburger button (mobile only) -->
  <label
    for="nav-toggle"
    class="hamburger-label md:hidden flex flex-col justify-center gap-[5px] cursor-pointer p-1"
    aria-label="Toggle menu"
  >
    <span class="hamburger-bar"></span>
    <span class="hamburger-bar"></span>
    <span class="hamburger-bar"></span>
  </label>

  <!-- Nav links -->
  <div class="nav-links">
    <a class="font-mono uppercase text-xs text-zinc-500 hover:text-zinc-300 transition-colors" href="#expertise">Expertise</a>
    <a class="font-mono uppercase text-xs text-zinc-500 hover:text-zinc-300 transition-colors" href="#milestones">Experience</a>
    <a class="font-mono uppercase text-xs text-zinc-500 hover:text-zinc-300 transition-colors" href="#projects">Projects</a>
    <a class="font-mono uppercase text-xs text-zinc-500 hover:text-zinc-300 transition-colors" href="#contact">Contact</a>

  </div>

  <!-- Contact button (desktop only) -->
  
   <a href="mailto:adrianneftali.s@gmail.com"
    class="hidden md:inline-block font-mono uppercase text-xs px-4 py-2 border border-secondary text-secondary hover:bg-secondary hover:text-on-secondary transition-all"
  >
    Contact
  </a>

</nav>