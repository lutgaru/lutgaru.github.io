---
// src/layouts/BaseLayout.astro
import "../styles/global.css";
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'SYSTEM_ARCHITECT_v1.0 | Senior Embedded Systems Engineer', description = '' } = Astro.props;
---

<!DOCTYPE html>
<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    

  </head>
  <body class="bg-background text-on-surface font-body-base selection:bg-primary-container selection:text-on-primary-container">
    <Header />
    
    <main class="pt-14 grid-lines">
      <slot />
    </main>
    
    <Footer />
    
    <!-- Global Styles -->
    <style is:global>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
      .grid-lines {
        background-image: radial-gradient(circle, #2f2722 1px, transparent 1px);
        background-size: 24px 24px;
      }
      .rust-glow { box-shadow: 0 0 20px rgba(183, 65, 14, 0.2); }
      .gold-glow { box-shadow: 0 0 20px rgba(212, 175, 55, 0.2); }
      
      @keyframes float {
        0%, 100% { transform: translateY(0) scale(1); }
        50% { transform: translateY(-15px) scale(1.02); }
      }
      @keyframes orbit {
        from { transform: rotate(0deg) translateX(140px) rotate(0deg); }
        to { transform: rotate(360deg) translateX(140px) rotate(-360deg); }
      }
      .levitate { animation: float 6s ease-in-out infinite; }
      .orbit-node { position: absolute; top: 50%; left: 50%; margin: -20px; }
      .orbit-1 { animation: orbit 20s linear infinite; }
      .orbit-2 { animation: orbit 25s linear infinite -5s; }
      .orbit-3 { animation: orbit 30s linear infinite -10s; }
      .orbit-4 { animation: orbit 35s linear infinite -15s; }
      .orbit-5 { animation: orbit 40s linear infinite -20s; }
      .orbit-6 { animation: orbit 45s linear infinite -25s; }
      .orbit-7 { animation: orbit 50s linear infinite -30s; }
    </style>
  </body>
</html>